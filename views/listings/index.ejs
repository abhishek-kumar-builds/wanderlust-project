<% layout("/layouts/boilerplate") %>
<body>
    <style>
      #filters {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
      }

      .filters {
        text-align: center;
        margin-right: 2rem;
        margin-top: 2rem;
        opacity: 0.7;
        text-decoration: none;
        color: inherit;
      }

      .filters:hover,
      .filters.active {
        opacity: 1;
        cursor: pointer;
        color: inherit;
      }

      .filters.active {
        border-bottom: 2px solid #fe424d;
        padding-bottom: 0.25rem;
      }

      .filter p {
        font-size: 0.8rem;
      }

      .tax-toggle {
        border: 1px solid black;
        border-radius: 1rem;
        height: 3.25rem;
        padding: 1rem;
        margin-left: 2rem;
        display: flex;
        align-items: center;
      }

      .no-results {
        text-align: center;
        margin-top: 3rem;
        opacity: 0.7;
      }
    </style>

    <% const activeCategory = typeof category !== 'undefined' ? category : 'trending'; %>
    <% const searchQuery = typeof q !== 'undefined' ? q : ''; %>

    <div id="filters">
      <a href="/listings<%= searchQuery ? '?q=' + encodeURIComponent(searchQuery) : '' %>" class="filters <%= activeCategory === 'trending' ? 'active' : '' %>">
        <div><i class="fa-solid fa-fire"></i></div>
        <p>Trending</p>
      </a>
      <a href="/listings?category=room<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="filters <%= activeCategory === 'room' ? 'active' : '' %>">
        <div><i class="fa-solid fa-bed"></i></div>
        <p>Room</p>
      </a>
      <a href="/listings?category=iconic-cities<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="filters <%= activeCategory === 'iconic-cities' ? 'active' : '' %>">
        <div><i class="fa-solid fa-mountain-city"></i></div>
        <p>Iconic Cities</p>
      </a>
      <a href="/listings?category=mountains<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="filters <%= activeCategory === 'mountains' ? 'active' : '' %>">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountains</p>
      </a>
      <a href="/listings?category=castles<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="filters <%= activeCategory === 'castles' ? 'active' : '' %>">
        <div><i class="fa-brands fa-fort-awesome"></i></div>
        <p>Castles</p>
      </a>
      <a href="/listings?category=amazing-pools<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="filters <%= activeCategory === 'amazing-pools' ? 'active' : '' %>">
        <div><i class="fa-solid fa-person-swimming"></i></div>
        <p>Amazing Pools</p>
      </a>
      <a href="/listings?category=camping<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="filters <%= activeCategory === 'camping' ? 'active' : '' %>">
        <div><i class="fa-solid fa-campground"></i></div>
        <p>Camping</p>
      </a>
      <a href="/listings?category=farm<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="filters <%= activeCategory === 'farm' ? 'active' : '' %>">
        <div><i class="fa-solid fa-seedling"></i></div>
        <p>Farm</p>
      </a>
      <a href="/listings?category=arctic<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="filters <%= activeCategory === 'arctic' ? 'active' : '' %>">
        <div><i class="fa-solid fa-person-skiing-nordic"></i></div>
        <p>Arctic</p>
      </a>
      <a href="/listings?category=domes<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="filters <%= activeCategory === 'domes' ? 'active' : '' %>">
        <div><i class="fa-solid fa-igloo"></i></div>
        <p>Domes</p>
      </a>
      <a href="/listings?category=boats<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="filters <%= activeCategory === 'boats' ? 'active' : '' %>">
        <div><i class="fa-solid fa-sailboat"></i></div>
        <p>Boats</p>
      </a>

      <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
          <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
          <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
        </div>
      </div>
    </div>

    <% if (allListings.length === 0) { %>
      <div class="no-results">
        <h4>No listings found</h4>
        <p>Try a different search or category filter.</p>
        <a href="/listings" class="btn btn-dark mt-2">View all listings</a>
      </div>
    <% } %>

    <div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-1 mt-3">
      <% for (let listing of allListings){ %>
        <% let imgSrc = listing.image?.url || listing.image || "https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=800"; %>
    <a href="/listings/<%= listing._id %>" class="listing-link">
      <div class="card col listing-card" >
      <img src="<%= imgSrc %>" class="card-img-top" alt="Listing_image" style="height : 20rem">
      <div class="card-img-overlay">
      </div>
      <div class="card-body">
        <p class="card-text">
          <b><%= listing.title %></b><br />
          &#8377;<%= listing.price.toLocaleString("en-IN") %>/night
          <i class="tax-info" style="display:none;"> &nbsp; &nbsp;+18% GST</i>
        </p>
      </div>
    </div>
    </a>
    <% } %>
    </div>

    <script>
      let taxSwitch = document.getElementById("switchCheckDefault");
      taxSwitch.addEventListener("click", () => {
        let taxInfo = document.getElementsByClassName("tax-info");
        for (info of taxInfo) {
          if (info.style.display != "inline") {
            info.style.display = "inline";
          } else {
            info.style.display = "none";
          }
        }
      });
    </script>

</body>
